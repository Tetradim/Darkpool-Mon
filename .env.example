# Darkpool Monitor Environment Variables

# =============================================================================
# Security
# =============================================================================

# Set this in production. Do not allow the app to generate a new secret on restart.
SECRET_KEY=replace_with_a_long_random_secret

# =============================================================================
# API Keys (optional - FINRA is free, others require paid accounts)
# =============================================================================

# Polygon.io - https://polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# Intrinio - https://intrinio.com  
INTRINIO_API_KEY=your_intrinio_api_key_here

# Unusual Whales - options flow, dark pool, GEX/VEX, news, halts
UNUSUAL_WHALES_API_KEY=your_unusual_whales_api_key_here

# =============================================================================
# Discord Bot (optional)
# =============================================================================

# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Optional: Your server ID for faster command registration
DISCORD_GUILD_ID=your_server_id_here

# Required for public Discord interaction webhooks.
DISCORD_PUBLIC_KEY=your_discord_application_public_key_here

# Set to true only for local tests or private development payloads.
ALLOW_UNSIGNED_DISCORD_INTERACTIONS=false

# =============================================================================
# Server Configuration
# =============================================================================

# Port for the FastAPI server (default: 8000)
PORT=8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# =============================================================================
# Alert Configuration
# =============================================================================

# Default whale alert threshold (shares)
WHALE_THRESHOLD=100000

# Discord webhook URL for alerts
DISCORD_WEBHOOK_URL=your_webhook_url_here
